# --- Frontend & Build Time Variables ---
# Next.js 編譯時需要的 API 地址
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Backend Runtime Variables ---
PORT=3001
NODE_ENV=development

# PostgreSQL (Prisma)
# Docker Compose 內部連線位址
DATABASE_URL="postgresql://omniscreen:omniscreen_dev@postgres:5432/omniscreen?schema=public"

# MinIO (S3 Compatible)
# Docker Compose 內部連線位址
MINIO_ENDPOINT="http://minio:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="omniscreen-assets"
MINIO_USE_SSL=false

# Authentication
JWT_SECRET="your_random_jwt_secret_here"
CMS_USER="admin"
CMS_PASS="omniscreen2024"

# LINE Messaging API (Offline Alert)
LINE_CHANNEL_TOKEN="YOUR_LINE_CHANNEL_ACCESS_TOKEN"
LINE_USER_ID="YOUR_LINE_USER_ID"