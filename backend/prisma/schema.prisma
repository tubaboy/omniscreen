generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Screen {
  id              String      @id @default(cuid())
  name            String
  orientation     Orientation @default(LANDSCAPE)
  lastSeen        DateTime    @default(now())
  status          String      @default("OFFLINE")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tags            String[]    @default([])
  latitude        Float?
  longitude       Float?
  lastSnapshotUrl String?
  snapshotAt      DateTime?
  systemInfo      Json?
  customBgUrl     String?
  schedules       Schedule[]
  commands        ScreenCommand[]
}

model ScreenCommand {
  id        String   @id @default(cuid())
  screenId  String
  type      String   // RELOAD, SNAPSHOT, CLEAR_CACHE
  status    String   @default("PENDING") // PENDING, COMPLETED
  createdAt DateTime @default(now())
  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@index([screenId])
  @@index([status])
}

model Asset {
  id           String         @id @default(cuid())
  name         String
  type         AssetType
  url          String
  thumbnailUrl String?
  duration     Int?           @default(10)
  orientation  Orientation    @default(LANDSCAPE)
  size         BigInt
  mimeType     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tags         String[]       @default([])
  validFrom    DateTime?
  validUntil   DateTime?
  playlists    PlaylistItem[]
  scheduledFrames Schedule[]   @relation("ScheduleFrame")
}

model Schedule {
  id         String         @id @default(cuid())
  name       String
  screenId   String
  startTime  String
  endTime    String
  daysOfWeek Int[]
  priority   Int            @default(1)
  isActive   Boolean        @default(true)
  transition String         @default("FADE")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  endDate    DateTime?
  startDate  DateTime?
  items      PlaylistItem[]
  frameId    String?
  frame      Asset?         @relation("ScheduleFrame", fields: [frameId], references: [id])
  layoutConfig Json?
  marqueeConfig Json?
  screen     Screen         @relation(fields: [screenId], references: [id], onDelete: Cascade)
}

model PlaylistItem {
  id         String   @id @default(cuid())
  scheduleId String
  assetId    String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  duration   Int?
  asset      Asset    @relation(fields: [assetId], references: [id])
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([assetId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PlaybackLog {
  id           String   @id @default(cuid())
  screenId     String
  scheduleId   String?
  assetId      String?
  playedAt     DateTime @default(now())
  duration     Int      @default(0)
  status       String   @default("SUCCESS")
  errorMessage String?

  @@index([screenId])
  @@index([assetId])
  @@index([scheduleId])
  @@index([playedAt])
}

model DailyPlaybackStats {
  id            String   @id @default(cuid())
  date          DateTime
  screenId      String
  assetId       String
  scheduleId    String?
  totalPlays    Int      @default(0)
  totalDuration Int      @default(0)
  errorCount    Int      @default(0)

  @@unique([date, screenId, assetId, scheduleId])
  @@index([date])
  @@index([screenId])
  @@index([assetId])
}

enum Orientation {
  LANDSCAPE
  PORTRAIT
}

enum AssetType {
  IMAGE
  VIDEO
  WIDGET
  WEB
  YOUTUBE
  MARQUEE
  CAMPAIGN
}
